# Domain for public hosting (HTTPS will be enabled automatically via Let's Encrypt)
# Use "localhost" for local development, or your actual domain for production
DOMAIN=localhost

# Database credentials
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_PASSWORD=your_password_here
MYSQL_USER=semantic_data_catalog
MYSQL_DATABASE=semantic_data_catalog

# SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password_here
EMAIL_FROM=your_email@example.com

# Fuseki admin password
FUSEKI_ADMIN_PASSWORD=change_this_password

# Solid Pod access token (optional)
SOLID_ACCESS_TOKEN=

# Catalog Registration Settings
CATALOG_ID=1
CATALOG_DEFAULT_CONTACT=timberconnect@2050.de
CATALOG_REGISTRATION_ENABLED=true
